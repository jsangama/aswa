rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function claimRole() {
      return signedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : '';
    }

    function claimBusinessId() {
      return signedIn() && request.auth.token.businessId is string
        ? request.auth.token.businessId
        : '';
    }

    function isOperator(businessId) {
      return signedIn() &&
        claimBusinessId() == businessId &&
        claimRole() in ['owner', 'admin', 'delivery'];
    }

    function isAdmin(businessId) {
      return signedIn() &&
        claimBusinessId() == businessId &&
        claimRole() in ['owner', 'admin'];
    }

    function isClientUpload(businessId) {
      return signedIn() &&
        request.resource.metadata.businessId == businessId &&
        request.resource.metadata.clienteUid == request.auth.uid;
    }

    function safeMedia(maxBytes) {
      return request.resource.size <= maxBytes &&
        request.resource.contentType.matches('image/.*|video/.*');
    }

    match /comprobantes/{businessId}/{fileName} {
      allow create: if isClientUpload(businessId) && safeMedia(10 * 1024 * 1024);
      allow read: if isOperator(businessId);
      allow update, delete: if isAdmin(businessId);
    }

    match /ugc/{businessId}/{fileName} {
      allow create: if isClientUpload(businessId) && safeMedia(20 * 1024 * 1024);
      allow read: if signedIn();
      allow update, delete: if isAdmin(businessId);
    }

    match /misiones/{businessId}/{fileName} {
      allow create: if isClientUpload(businessId) && safeMedia(20 * 1024 * 1024);
      allow read: if isOperator(businessId) || (
        signedIn() &&
        resource.metadata.businessId == businessId &&
        resource.metadata.clienteUid == request.auth.uid
      );
      allow update, delete: if isAdmin(businessId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
