rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function claimRole() {
      return signedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : '';
    }

    function claimBusinessId() {
      return signedIn() && request.auth.token.businessId is string
        ? request.auth.token.businessId
        : '';
    }

    function sameBusiness(data) {
      return signedIn() &&
        (
          (data.businessId is string && claimBusinessId() == data.businessId) ||
          (data.business_id is string && claimBusinessId() == data.business_id)
        );
    }

    function hasBusinessId(data) {
      return data.businessId is string || data.business_id is string;
    }

    function canManageBusinessDoc(resourceData) {
      return isAdmin(request.resource.data) && (
        (hasBusinessId(resourceData) && sameBusiness(resourceData) && sameBusiness(request.resource.data)) ||
        (!hasBusinessId(resourceData) && sameBusiness(request.resource.data))
      );
    }

    function canDeleteBusinessDoc(resourceData) {
      return (
        (hasBusinessId(resourceData) && sameBusiness(resourceData)) ||
        (!hasBusinessId(resourceData) && claimRole() in ['owner', 'admin'])
      );
    }

    function isClientOwner(data) {
      return signedIn() &&
        data.cliente_uid is string &&
        data.cliente_uid == request.auth.uid;
    }

    function isClientOwnedCreate() {
      return signedIn() &&
        request.resource.data.cliente_uid == request.auth.uid &&
        hasBusinessId(request.resource.data);
    }

    function isOwner(data) {
      return sameBusiness(data) && claimRole() == 'owner';
    }

    function isAdmin(data) {
      return sameBusiness(data) && claimRole() in ['owner', 'admin'];
    }

    function isDelivery(data) {
      return sameBusiness(data) && claimRole() in ['owner', 'admin', 'delivery'];
    }

    function isPedidoOwner(data) {
      return isClientOwner(data);
    }

    function validPedidoCreate() {
      return signedIn() &&
        request.resource.data.businessId is string &&
        request.resource.data.cliente_uid == request.auth.uid &&
        request.resource.data.estado == 'Pendiente' &&
        request.resource.data.keys().hasAll([
          'businessId', 'cliente_uid', 'nombre', 'telefono',
          'items', 'total', 'pago', 'estado', 'fecha'
        ]) &&
        request.resource.data.keys().hasOnly([
          'businessId', 'cliente_uid', 'nombre', 'telefono', 'direccion',
          'nota_entrega', 'distrito', 'items', 'items_detalle', 'subtotal',
          'delivery', 'oferta_pct', 'descuento_amt', 'cupon_codigo',
          'cupon_descuento_pct', 'cupon_descuento_fijo', 'total', 'pago',
          'pago_con', 'vuelto', 'codigo_usado', 'nivel_cliente', 'estado',
          'es_prueba', 'prueba_modo', 'prueba_origen',
          'confirmacion_cliente', 'gps_url', 'gps_coords', 'yape_foto_url',
          'yape_foto_base64', 'yape_estado', 'yape_verificacion',
          'yape_foto_local', 'requiere_comprobante_whatsapp', 'compartido',
          'asignado_a', 'es_reserva', 'reserva_fecha', 'reserva_hora',
          'reserva_iso', 'reserva_texto', 'reserva_estado',
          'reserva_alertas_cliente', 'es_regalo', 'regalo_para',
          'es_promo_san_juan_escolar', 'promo_san_juan_escolar',
          'es_promo_san_juan_institucional', 'promo_san_juan_institucional',
          'pago_anticipado_obligatorio', 'planta_coords',
          'distancia_planta_m', 'distancia_planta_txt', 'delivery_carga',
          'delivery_carga_confirmada', 'admin_alerta_nueva',
          'delivery_alerta_nueva', 'fecha'
        ]);
    }

    function validClienteSelfWrite() {
      return isClientOwnedCreate() &&
        request.resource.data.keys().hasOnly([
          'businessId', 'cliente_uid', 'nombre', 'telefono', 'nivel',
          'pedidos_totales', 'total_consumo', 'ultimo_pedido',
          'codigo_referido', 'bonos_activos'
        ]);
    }

    function validReferralCodeWrite(codigo) {
      return signedIn() &&
        request.resource.data.businessId is string &&
        request.resource.data.codigo == codigo &&
        request.resource.data.cliente_uid == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'businessId', 'codigo', 'cliente_uid', 'activo',
          'created_at', 'updated_at'
        ]);
    }

    function validReferralEventCreate() {
      return signedIn() &&
        request.resource.data.businessId is string &&
        request.resource.data.cliente_uid == request.auth.uid &&
        request.resource.data.estado == 'pendiente' &&
        request.resource.data.keys().hasOnly([
          'businessId', 'cliente_uid', 'codigo_usado', 'pedido_id',
          'telefono_nuevo', 'nombre_nuevo', 'estado', 'created_at'
        ]);
    }

    function clientConfirmOnly() {
      return isPedidoOwner(resource.data) &&
        request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['confirmacion_cliente', 'confirmado_at', 'estado', 'updated_at']) &&
        request.resource.data.confirmacion_cliente == true &&
        request.resource.data.estado in ['en_camino', resource.data.estado];
    }

    match /pedidos/{pedidoId} {
      allow create: if validPedidoCreate();
      allow read: if isAdmin(resource.data) || isDelivery(resource.data) || isPedidoOwner(resource.data);
      allow update: if isAdmin(resource.data) || isDelivery(resource.data) || clientConfirmOnly();
      allow delete: if isAdmin(resource.data);
    }

    match /pedidos_prueba/{pedidoId} {
      allow create: if validPedidoCreate() && request.resource.data.es_prueba == true;
      allow read: if isAdmin(resource.data) || isDelivery(resource.data) || isPedidoOwner(resource.data);
      allow update: if isAdmin(resource.data) || isDelivery(resource.data) || clientConfirmOnly();
      allow delete: if isAdmin(resource.data);
    }

    match /clientes/{clienteId} {
      allow create: if validClienteSelfWrite();
      allow read: if isAdmin(resource.data) || isClientOwner(resource.data);
      allow update: if isAdmin(resource.data) || (
        isClientOwner(resource.data) &&
        request.resource.data.cliente_uid == resource.data.cliente_uid &&
        request.resource.data.businessId == resource.data.businessId &&
        request.resource.data.keys().hasOnly([
          'businessId', 'cliente_uid', 'nombre', 'telefono', 'nivel',
          'pedidos_totales', 'total_consumo', 'ultimo_pedido',
          'codigo_referido', 'bonos_activos'
        ])
      );
      allow delete: if isAdmin(resource.data);
    }

    match /clientes_prueba/{clienteId} {
      allow create: if validClienteSelfWrite();
      allow read: if isAdmin(resource.data) || isClientOwner(resource.data);
      allow update: if isAdmin(resource.data) || (
        isClientOwner(resource.data) &&
        request.resource.data.cliente_uid == resource.data.cliente_uid &&
        request.resource.data.businessId == resource.data.businessId &&
        request.resource.data.keys().hasOnly([
          'businessId', 'cliente_uid', 'nombre', 'telefono', 'nivel',
          'pedidos_totales', 'total_consumo', 'ultimo_pedido',
          'codigo_referido', 'bonos_activos'
        ])
      );
      allow delete: if isAdmin(resource.data);
    }

    match /referral_codes/{codigo} {
      allow read: if true;
      allow create: if validReferralCodeWrite(codigo) || isAdmin(request.resource.data);
      allow update: if (
        validReferralCodeWrite(codigo) &&
        resource.data.cliente_uid == request.auth.uid &&
        request.resource.data.businessId == resource.data.businessId
      ) || isAdmin(resource.data) || isAdmin(request.resource.data);
      allow delete: if isAdmin(resource.data);
    }

    match /referral_events/{eventId} {
      allow create: if validReferralEventCreate();
      allow read: if isAdmin(resource.data) || isClientOwner(resource.data);
      allow update, delete: if isAdmin(resource.data);
    }

    match /app_users/{userId} {
      allow read, write: if isOwner(resource.data) || isOwner(request.resource.data);
    }

    match /productos/{productoId} {
      allow read: if true;
      allow create: if isAdmin(request.resource.data);
      allow update: if canManageBusinessDoc(resource.data);
      allow delete: if canDeleteBusinessDoc(resource.data);
    }

    match /cupones/{cuponId} {
      allow read: if true;
      allow create: if isAdmin(request.resource.data);
      allow update: if canManageBusinessDoc(resource.data);
      allow delete: if canDeleteBusinessDoc(resource.data);
    }

    match /catalogo/{productoId} {
      allow read: if true;
      allow create: if isAdmin(request.resource.data);
      allow update: if canManageBusinessDoc(resource.data);
      allow delete: if canDeleteBusinessDoc(resource.data);
    }

    match /fcm_tokens/{tokenId} {
      allow create, update: if isClientOwnedCreate();
      allow read, delete: if isAdmin(resource.data);
    }

    match /sugerencias/{sugerenciaId} {
      allow create: if isClientOwnedCreate();
      allow read: if true;
      allow update, delete: if isAdmin(resource.data) || isAdmin(request.resource.data);
    }

    match /evidencias/{evidenciaId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin(resource.data) || isAdmin(request.resource.data);
    }

    match /ugc_posts/{postId} {
      allow create: if isClientOwnedCreate();
      allow read: if resource.data.estado == 'aprobado' || isAdmin(resource.data) || isClientOwner(resource.data);
      allow update, delete: if isAdmin(resource.data);
    }

    match /evidencias_misiones/{evidenciaId} {
      allow create: if isClientOwnedCreate();
      allow read: if isAdmin(resource.data) || isClientOwner(resource.data);
      allow update, delete: if isAdmin(resource.data);
    }

    match /calificaciones/{calificacionId} {
      allow create: if isClientOwnedCreate();
      allow read: if resource.data.visible == true || isAdmin(resource.data) || isClientOwner(resource.data);
      allow update, delete: if isAdmin(resource.data);
    }

    match /push_queue/{pushId} {
      allow create: if isClientOwnedCreate() || isAdmin(request.resource.data);
      allow read, update, delete: if isAdmin(resource.data) || isAdmin(request.resource.data);
    }

    match /pagos_culqi/{pagoId} {
      allow create: if isClientOwnedCreate();
      allow read: if isAdmin(resource.data) || isClientOwner(resource.data);
      allow update, delete: if isAdmin(resource.data);
    }

    match /dlv_tracking/{trackingId} {
      allow create: if isDelivery(request.resource.data);
      allow read: if isDelivery(resource.data);
      allow update, delete: if isAdmin(resource.data);
    }

    match /dlv_accesos/{accesoId} {
      allow create: if isDelivery(request.resource.data);
      allow read, update, delete: if isAdmin(resource.data);
    }

    match /chats/{chatId} {
      allow create: if isClientOwnedCreate() || isAdmin(request.resource.data);
      allow read, update: if isAdmin(resource.data) || isClientOwner(resource.data);
      allow delete: if isAdmin(resource.data);

      match /mensajes/{mensajeId} {
        allow create, read: if signedIn() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.cliente_uid == request.auth.uid ||
          isAdmin(get(/databases/$(database)/documents/chats/$(chatId)).data)
        );
        allow update, delete: if isAdmin(get(/databases/$(database)/documents/chats/$(chatId)).data);
      }
    }

    match /negocios/{businessId} {
      allow read: if true;
      allow write: if signedIn() &&
        claimBusinessId() == businessId &&
        claimRole() in ['owner', 'admin'];
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
