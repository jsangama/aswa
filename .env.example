# ASWA Platform configuration template
#
# Copy to .env for local tooling. Browser-only deployments should copy
# js/local-config.example.js to js/local-config.js and keep it uncommitted.

BUSINESS_ID=aswa001
BUSINESS_NAME=La Rica Chicha

FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=pedidos-aswa-peru.firebaseapp.com
FIREBASE_PROJECT_ID=pedidos-aswa-peru
FIREBASE_STORAGE_BUCKET=pedidos-aswa-peru.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=213964983594
FIREBASE_APP_ID=your_firebase_app_id

ADMIN_PIN=change_me
DELIVERY_PIN=change_me
ADMIN_PASSWORD=change_me
DELIVERY_PASSWORD=change_me

WHATSAPP_1=51955273229
WHATSAPP_2=51986445531
WHATSAPP_YAPE=51947999736

# Automatic SUNAT/PSE receipt emission through a secure provider API.
# Never store Clave SOL in the app. Configure the provider endpoint/key in Firebase Functions.
FACTURACION_API_URL=
FACTURACION_SERIE_BOLETA=B001
FACTURACION_SERIE_FACTURA=F001
# Secret name in Firebase Functions:
# firebase functions:secrets:set FACTURACION_API_KEY

NODE_ENV=development
